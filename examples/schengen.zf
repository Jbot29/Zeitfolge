# The Schengen 90/180 rule: at most 90 days inside the zone in ANY
# trailing 180-day window. That's a windowed aggregation — this file
# replaces an 86-line hand-rolled Python script.

timezone = Europe/Vienna

trips = 2023-12-01 .. 2023-12-18,
        2024-02-23 .. 2024-03-09,
        2024-07-01 .. 2024-07-13

days of trips & last 180 days          # used as of today

rolling days of trips in 180 days limit 90


